{
  "name": "@open-syria/website",
  "version": "0.3.1",
  "private": true,
  "description": "OpenSyria public website.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "check:write:unsafe": "biome check --write --unsafe .",
    "dev": "next dev",
    "format": "biome format --write .",
    "images:brand": "node scripts/generate-brand-images.mjs",
    "lint": "biome lint .",
    "prepare": "husky",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "verify": "biome check . && tsc --noEmit && next build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@next/third-parties": "16.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-intl": "4.13.1",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "schema-dts": "^2.0.0",
    "sharp": "0.35.3",
    "tailwindcss": "4.3.1",
    "typescript": "^6"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  }
}
